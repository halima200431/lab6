<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/cardBackground"
    android:layout_marginHorizontal="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:padding="0dp">

        <!-- Image de la pizza -->
        <ImageView
            android:id="@+id/imgPizza"
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>

        <!-- Dégradé sur l'image pour effet visuel -->
        <View
            android:layout_width="30dp"
            android:layout_height="match_parent"
            android:layout_toRightOf="@id/imgPizza"
            android:background="@android:color/transparent"/>

        <!-- Nom de la pizza -->
        <TextView
            android:id="@+id/tvNom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/imgPizza"
            android:layout_marginStart="14dp"
            android:layout_marginTop="14dp"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/textPrimary"
            android:maxLines="2"/>

        <!-- Icône personnes + nombre -->
        <ImageView
            android:id="@+id/iconPersonnes"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_toRightOf="@id/imgPizza"
            android:layout_below="@id/tvNom"
            android:layout_marginStart="14dp"
            android:layout_marginTop="8dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:tint="#BDBDBD"/>

        <TextView
            android:id="@+id/tvPrix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/iconPersonnes"
            android:layout_below="@id/tvNom"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:textColor="@color/textSecondary"/>

        <!-- Icône horloge + durée -->
        <ImageView
            android:id="@+id/iconDuree"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_toRightOf="@id/imgPizza"
            android:layout_below="@id/tvPrix"
            android:layout_marginStart="14dp"
            android:layout_marginTop="6dp"
            android:src="@android:drawable/ic_menu_recent_history"
            android:tint="#BDBDBD"/>

        <TextView
            android:id="@+id/tvDuree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/iconDuree"
            android:layout_below="@id/tvPrix"
            android:layout_marginStart="4dp"
            android:layout_marginTop="6dp"
            android:textSize="13sp"
            android:textColor="@color/textSecondary"/>

        <!-- Flèche à droite -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#E0E0E0"/>
    </RelativeLayout>
</androidx.cardview.widget.CardView>